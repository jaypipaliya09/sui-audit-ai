# Next.js web. Reuses the shared deps image. NEXT_PUBLIC_API_URL is baked at build time.
FROM sui-deps:latest AS build
WORKDIR /repo
# Overlay current web + shared-types source over the copy baked into the deps image
COPY apps/web /repo/apps/web
COPY packages/shared-types /repo/packages/shared-types
ARG NEXT_PUBLIC_API_URL
ARG NEXT_PUBLIC_DEMO_WALLET_ADDRESS
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL \
    NEXT_PUBLIC_DEMO_WALLET_ADDRESS=$NEXT_PUBLIC_DEMO_WALLET_ADDRESS \
    NODE_OPTIONS=--max-old-space-size=1536
RUN npm run build --workspace web

FROM node:20-bookworm-slim
ENV NODE_ENV=production PORT=3000
WORKDIR /repo
COPY --from=build /repo /repo
WORKDIR /repo/apps/web
EXPOSE 3000
CMD ["npm", "run", "start"]
