# --- Report generation (Groq) ---
# Get your free Groq API key from https://console.groq.com/keys
GROQ_API_KEY=

# --- Sui network ---
SUI_NETWORK=testnet
# Optional override of the fullnode RPC URL
# SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# --- Escrow contract (Model A) ---
# Package id printed after `sui client publish` of apps/contracts
ESCROW_PACKAGE_ID=
# Address that receives captured (deposited) payments
TREASURY_ADDRESS=

# --- Payment asset (USDC on testnet) ---
# Defaults to Circle's testnet USDC; override for another network/asset.
USDC_COIN_TYPE=0xa1ec7fc00a6f40db9693ad1415d0c193ad3906494428cf252621037bd7117e29::usdc::USDC
USDC_DECIMALS=6

# Payer key the CLI uses to sign the escrow lock + refund.
# Accepts a `suiprivkey1...` bech32 key or a base64 Ed25519 secret key.
MOVE_AUDITOR_SECRET_KEY=

# Treasury key used to sign `capture` on success (operator/testnet).
# Leave empty in production and finalize capture via the backend instead.
TREASURY_SECRET_KEY=

# --- Slush wallet validation ---
# Base URL of the Slush API (leave empty to validate via Sui RPC only)
SLUSH_API_URL=
SLUSH_API_KEY=

# --- Backend (per-user report UI) ---
# When set, finished runs are uploaded here for the dashboard
BACKEND_URL=http://localhost:3001
# Web app URL printed in the terminal so the user can open their report
FRONTEND_URL=http://localhost:3000

# Dry-run the whole flow without moving real funds
# MOVE_AUDITOR_MOCK_PAYMENT=1
