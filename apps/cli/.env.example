# ============================================================
# Move Auditor — Developer / CI environment variables
# ============================================================
#
# USERS: You do NOT need this file.
# Run `move-auditor setup` once and your settings will be
# stored securely in ~/.move-auditor/config.json.
#
# DEVELOPERS / CI: Copy this file to .env and fill in the values.
# ============================================================

# Your personal Groq API key (free at https://console.groq.com/keys)
# Used to generate the audit Markdown report.
GROQ_API_KEY=

# Payer wallet secret key for escrow transactions.
# Accepts a `suiprivkey1...` bech32 key (Sui CLI export) or a base64 Ed25519 key.
MOVE_AUDITOR_SECRET_KEY=

# ---- Everything below is operator-managed (already hardcoded in config.ts) ----
# Override these ONLY if you are developing locally with a custom deployment.

# SUI_NETWORK=testnet
# SUI_RPC_URL=https://fullnode.testnet.sui.io:443
# ESCROW_PACKAGE_ID=
# TREASURY_ADDRESS=
# BACKEND_URL=http://localhost:3001
# FRONTEND_URL=http://localhost:3000

# Dry-run the whole flow without moving real funds
# MOVE_AUDITOR_MOCK_PAYMENT=1
